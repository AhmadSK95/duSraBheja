# Database
DATABASE_URL=postgresql+asyncpg://brain_user:changeme@db-host:25060/brain_db
DB_PASSWORD=changeme
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_STATEMENT_TIMEOUT_MS=30000
DB_SSL=true
DB_SSL_REQUIRE=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Redis
REDIS_URL=redis://localhost:6379

# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_numeric_guild_id
INBOX_CHANNEL_NAME=inbox
NEEDS_REVIEW_CHANNEL_NAME=needs-review
DAILY_DIGEST_CHANNEL_NAME=daily-digest
ASK_CHANNEL_NAME=ask-brain
BRAIN_VOICE_INSTRUCTIONS=Write like Ahmad: direct, thoughtful, low-fluff, builder-operator energy.

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_key

# OpenAI (embeddings + Whisper)
OPENAI_API_KEY=your_openai_key

# Private API
API_TOKEN=replace_with_long_random_token
API_HOST=0.0.0.0
API_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000

# MCP
MCP_TRANSPORT=streamable-http
MCP_PORT=8100

# Classification
CONFIDENCE_THRESHOLD=0.75
MAX_CLARIFICATION_ATTEMPTS=2
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# Blob storage
BLOB_STORAGE_PATH=/data/blobs
ENCRYPTION_MASTER_KEY=replace_with_32_byte_urlsafe_base64_key

# Digest
DIGEST_CRON_HOUR=8
DIGEST_TIMEZONE=America/New_York
DIGEST_STORY_PULSE_COOLDOWN_MINUTES=15
KNOWLEDGE_REFRESH_HOURS=6
KNOWLEDGE_MAX_PROJECTS_PER_RUN=3
COGNITION_REFRESH_HOURS=4
VOICE_REFRESH_HOUR=5

# Optional GitHub sync
GITHUB_API_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com

# Optional collector
COLLECTOR_DEVICE_NAME=macbook
COLLECTOR_INTERVAL_HOURS=12
COLLECTOR_PROJECT_ROOTS=/abs/path/to/repo-one,/abs/path/to/repo-two
# One-time bootstrap discovery roots. Use scripts/bootstrap_collector_batches.sh so these
# are expanded into exact repo roots (.git marker required) plus standalone context workspaces.
COLLECTOR_BOOTSTRAP_ROOTS=/Users/you/Desktop,/Users/you/Documents
# Optional non-repo roots to snapshot once during bootstrap, such as Downloads.
COLLECTOR_BOOTSTRAP_INVENTORY_ROOTS=/Users/you/Downloads
# Daily sync should normally be explicit repo/context roots, not broad parent folders.
COLLECTOR_DAILY_ROOTS=/abs/path/to/repo-one,/abs/path/to/repo-two,/abs/path/to/context-workspace
COLLECTOR_STATE_PATH=~/.brain-collector/state.json
# Collector uploads are relayed through SSH on each run; the API can stay bound to localhost.
COLLECTOR_API_BASE_URL=http://127.0.0.1:18000
COLLECTOR_SCAN_MAX_DEPTH=4
COLLECTOR_INVENTORY_RECENT_FILES_LIMIT=50
AGENT_HISTORY_STATE_PATH=~/.brain-collector/agent-history-state.json
AGENT_HISTORY_IDLE_SECONDS=300
AGENT_HISTORY_POLL_SECONDS=900
APPLE_NOTES_EXPORT_PATH=~/.brain-collector/apple-notes
APPLE_NOTES_STATE_PATH=~/.brain-collector/apple-notes-state.json
APPLE_NOTES_EXCLUDE_FOLDERS=
STORY_MAX_EVENTS=25
